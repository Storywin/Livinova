generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Partner {
  id            String               @id @default(uuid())
  name          String
  email         String               @unique
  phone         String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  subscriptions ErpSubscription[]
  licenseQuotas PartnerLicenseQuota?
  pricingPlans  PricingPlan[]
  tenants       Tenant[]
}

model Tenant {
  id         String             @id @default(uuid())
  partnerId  String?
  name       String
  slug       String             @unique
  status     SubscriptionStatus @default(trial)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  accounts   ErpAccount[]
  customers  ErpCustomer[]
  projects   ErpProject[]
  warehouses ErpWarehouse[]
  invoices   Invoice[]
  licenses   License[]
  partner    Partner?           @relation(fields: [partnerId], references: [id])
  users      User[]             @relation("TenantUsers")

  @@index([partnerId])
}

model PricingPlan {
  id           String               @id @default(uuid())
  ownerType    PricingPlanOwnerType
  ownerId      String?
  name         String
  description  String?
  durationDays Int
  price        Decimal              @db.Decimal(18, 2)
  isActive     Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  invoices     Invoice[]
  partner      Partner?             @relation(fields: [ownerId], references: [id])

  @@index([ownerId])
}

model PartnerLicenseQuota {
  id         String   @id @default(uuid())
  partnerId  String   @unique
  totalQuota Int
  usedQuota  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  partner    Partner  @relation(fields: [partnerId], references: [id])
}

model Invoice {
  id            String        @id @default(uuid())
  tenantId      String
  pricingPlanId String
  amount        Decimal       @db.Decimal(18, 2)
  status        PaymentStatus @default(pending)
  dueDate       DateTime
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  pricingPlan   PricingPlan   @relation(fields: [pricingPlanId], references: [id])
  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  payment       Payment?

  @@index([tenantId])
  @@index([status])
}

model Payment {
  id            String        @id @default(uuid())
  invoiceId     String        @unique
  amount        Decimal       @db.Decimal(18, 2)
  paymentMethod String?
  transactionId String?       @unique
  status        PaymentStatus @default(pending)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  invoice       Invoice       @relation(fields: [invoiceId], references: [id])
}

model ErpSubscription {
  id        String             @id @default(uuid())
  partnerId String
  package   String
  status    SubscriptionStatus @default(active)
  startDate DateTime
  endDate   DateTime
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  partner   Partner            @relation(fields: [partnerId], references: [id])

  @@index([partnerId])
}

model License {
  id          String        @id @default(uuid())
  userId      String
  tenantId    String
  deviceHash  String?       @unique
  deviceName  String?
  status      LicenseStatus @default(active)
  startDate   DateTime
  endDate     DateTime
  lastLoginAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deviceLogs  DeviceLog[]
  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  user        User          @relation(fields: [userId], references: [id])
  resets      LicenseReset?

  @@index([userId])
  @@index([tenantId])
}

model DeviceLog {
  id         String   @id @default(uuid())
  licenseId  String
  deviceHash String
  ipAddress  String?
  loginAt    DateTime @default(now())
  status     String
  license    License  @relation(fields: [licenseId], references: [id])

  @@index([licenseId])
}

model LicenseReset {
  id          String    @id @default(uuid())
  licenseId   String    @unique
  resetCount  Int       @default(0)
  lastResetAt DateTime?
  license     License   @relation(fields: [licenseId], references: [id])
}

model Permission {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model ErpProject {
  id          String     @id @default(uuid())
  tenantId    String
  name        String
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  sales       ErpSales[]
  units       ErpUnit[]

  @@index([tenantId])
}

model ErpUnit {
  id        String     @id @default(uuid())
  projectId String
  unitCode  String
  price     Decimal    @db.Decimal(18, 2)
  status    String     @default("available")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  sales     ErpSales[]
  project   ErpProject @relation(fields: [projectId], references: [id])

  @@unique([projectId, unitCode])
}

model ErpCustomer {
  id        String     @id @default(uuid())
  tenantId  String
  name      String
  email     String?
  phone     String?
  address   String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  leads     ErpLead[]
  sales     ErpSales[]

  @@index([tenantId])
}

model ErpLead {
  id         String       @id @default(uuid())
  customerId String?
  source     String
  status     String       @default("new")
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  customer   ErpCustomer? @relation(fields: [customerId], references: [id])
}

model ErpSales {
  id         String                 @id @default(uuid())
  tenantId   String
  projectId  String
  unitId     String
  customerId String
  status     ErpSalesStatus         @default(draft)
  totalPrice Decimal                @db.Decimal(18, 2)
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  documents  ErpGeneratedDocument[]
  payments   ErpPayment[]
  customer   ErpCustomer            @relation(fields: [customerId], references: [id])
  project    ErpProject             @relation(fields: [projectId], references: [id])
  unit       ErpUnit                @relation(fields: [unitId], references: [id])

  @@index([tenantId])
}

model ErpPayment {
  id        String           @id @default(uuid())
  salesId   String
  amount    Decimal          @db.Decimal(18, 2)
  dueDate   DateTime
  paidDate  DateTime?
  status    ErpPaymentStatus @default(pending)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  sales     ErpSales         @relation(fields: [salesId], references: [id])
}

model ErpAccount {
  id        String             @id @default(uuid())
  tenantId  String
  code      String
  name      String
  type      String
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  tenant    Tenant             @relation(fields: [tenantId], references: [id])
  details   ErpJournalDetail[]

  @@unique([tenantId, code])
}

model ErpJournal {
  id          String             @id @default(uuid())
  tenantId    String
  date        DateTime
  description String
  reference   String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  details     ErpJournalDetail[]

  @@index([tenantId])
}

model ErpJournalDetail {
  id        String     @id @default(uuid())
  journalId String
  accountId String
  debit     Decimal    @default(0) @db.Decimal(18, 2)
  credit    Decimal    @default(0) @db.Decimal(18, 2)
  account   ErpAccount @relation(fields: [accountId], references: [id])
  journal   ErpJournal @relation(fields: [journalId], references: [id])

  @@index([journalId])
  @@index([accountId])
}

model ErpWarehouse {
  id        String             @id @default(uuid())
  tenantId  String
  name      String
  location  String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  movements ErpStockMovement[]
  tenant    Tenant             @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model ErpMaterial {
  id        String             @id @default(uuid())
  name      String
  unit      String
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  movements ErpStockMovement[]
}

model ErpStockMovement {
  id          String       @id @default(uuid())
  warehouseId String
  materialId  String
  quantity    Decimal      @db.Decimal(18, 2)
  type        String
  createdAt   DateTime     @default(now())
  material    ErpMaterial  @relation(fields: [materialId], references: [id])
  warehouse   ErpWarehouse @relation(fields: [warehouseId], references: [id])

  @@index([warehouseId])
  @@index([materialId])
}

model ErpVendor {
  id        String             @id @default(uuid())
  name      String
  email     String?
  phone     String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  orders    ErpPurchaseOrder[]
}

model ErpPurchaseOrder {
  id        String    @id @default(uuid())
  vendorId  String
  total     Decimal   @db.Decimal(18, 2)
  status    String    @default("draft")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  vendor    ErpVendor @relation(fields: [vendorId], references: [id])

  @@index([vendorId])
}

model ErpDocumentTemplate {
  id                 String                 @id @default(uuid())
  name               String
  content            String
  type               String
  variables          Json?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  generatedDocuments ErpGeneratedDocument[]
}

model ErpGeneratedDocument {
  id         String              @id @default(uuid())
  templateId String
  salesId    String
  content    String
  status     ErpDocumentStatus   @default(draft)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  sales      ErpSales            @relation(fields: [salesId], references: [id])
  template   ErpDocumentTemplate @relation(fields: [templateId], references: [id])

  @@index([templateId])
  @@index([salesId])
}

model Role {
  id          String           @id @default(uuid())
  name        RoleName         @unique
  createdAt   DateTime         @default(now())
  permissions RolePermission[]
  users       UserRole[]
}

model User {
  id                  String               @id @default(uuid())
  email               String               @unique
  passwordHash        String
  name                String?
  phone               String?
  status              UserStatus           @default(active)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  tenantId            String?
  auditLogs           AuditLog[]           @relation("AuditActor")
  compareLists        CompareList[]
  developerIds        DeveloperUser[]
  favorites           Favorite[]
  inquiries           Inquiry[]
  leads               Lead[]
  licenses            License[]
  mortgageSimulations MortgageSimulation[]
  refresh             RefreshToken[]
  tenant              Tenant?              @relation("TenantUsers", fields: [tenantId], references: [id])
  roles               UserRole[]
  verificationReviews VerificationRecord[] @relation("VerificationReviewer")
  viewingRequests     ViewingRequest[]

  @@index([createdAt])
}

model UserRole {
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String
  createdAt DateTime  @default(now())
  expiresAt DateTime
  revokedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Developer {
  id                 String              @id @default(uuid())
  name               String
  slug               String              @unique
  description        String?
  website            String?
  email              String?
  phone              String?
  address            String?
  city               String?
  province           String?
  contactPersonName  String?
  contactPersonEmail String?
  contactPersonPhone String?
  verificationStatus VerificationStatus  @default(pending)
  verificationNotes  String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  profileTemplate    String              @default("classic")
  companyType        String?
  contactPersonRole  String?
  establishedYear    Int?
  portfolioUrl       String?
  adCampaigns        AdCampaign[]
  documents          DeveloperDocument[]
  members            DeveloperUser[]
  projects           Project[]

  @@index([verificationStatus])
}

model DeveloperUser {
  id          String    @id @default(uuid())
  developerId String
  userId      String
  createdAt   DateTime  @default(now())
  developer   Developer @relation(fields: [developerId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([developerId, userId])
  @@index([userId])
}

model DeveloperDocument {
  id           String                @id @default(uuid())
  developerId  String
  type         DeveloperDocumentType
  status       DocumentStatus        @default(uploaded)
  mediaAssetId String
  notes        String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  developer    Developer             @relation(fields: [developerId], references: [id], onDelete: Cascade)
  mediaAsset   MediaAsset            @relation(fields: [mediaAssetId], references: [id])

  @@index([developerId])
  @@index([status])
}

model Project {
  id                 String              @id @default(uuid())
  developerId        String
  name               String
  slug               String              @unique
  description        String?
  status             ProjectStatus       @default(under_development)
  smartReadiness     SmartReadinessLevel @default(none)
  verificationStatus VerificationStatus  @default(pending)
  startingPrice      Decimal?            @db.Decimal(18, 2)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  adCampaigns        AdCampaign[]
  developer          Developer           @relation(fields: [developerId], references: [id], onDelete: Cascade)
  location           ProjectLocation?
  listings           PropertyListing[]
  units              PropertyUnit[]

  @@index([developerId])
  @@index([verificationStatus])
  @@index([status])
}

model ProjectLocation {
  id         String   @id @default(uuid())
  projectId  String   @unique
  address    String?
  city       String?
  area       String?
  province   String?
  postalCode String?
  latitude   Float?
  longitude  Float?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model PropertyUnit {
  id             String            @id @default(uuid())
  projectId      String
  title          String
  slug           String
  propertyType   PropertyType
  bedrooms       Int?
  bathrooms      Int?
  buildingSize   Int?
  landSize       Int?
  price          Decimal?          @db.Decimal(18, 2)
  startingPrice  Decimal?          @db.Decimal(18, 2)
  availableUnits Int?              @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  listings       PropertyListing[]
  project        Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, slug])
  @@index([projectId])
  @@index([propertyType])
}

model PropertyListing {
  id                   String                 @id @default(uuid())
  projectId            String
  unitId               String?
  title                String
  slug                 String                 @unique
  status               ListingStatus          @default(draft)
  verificationStatus   VerificationStatus     @default(pending)
  featured             Boolean                @default(false)
  sponsored            Boolean                @default(false)
  recommended          Boolean                @default(false)
  price                Decimal?               @db.Decimal(18, 2)
  startingPrice        Decimal?               @db.Decimal(18, 2)
  description          String?
  specs                Json?
  smartHomeDetails     Json?
  brochureMediaAssetId String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  adCampaigns          AdCampaign[]
  compareItems         CompareItem[]
  favorites            Favorite[]
  inquiries            Inquiry[]
  leads                Lead[]
  mortgageSimulations  MortgageSimulation[]
  images               PropertyImage[]
  brochureMediaAsset   MediaAsset?            @relation("BrochureAsset", fields: [brochureMediaAssetId], references: [id])
  project              Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  unit                 PropertyUnit?          @relation(fields: [unitId], references: [id])
  ratings              PropertyRating[]
  smartFeatures        PropertySmartFeature[]
  viewingRequests      ViewingRequest[]

  @@index([projectId])
  @@index([status])
  @@index([verificationStatus])
  @@index([featured])
}

model PropertyImage {
  id           String          @id @default(uuid())
  listingId    String
  mediaAssetId String
  sortOrder    Int             @default(0)
  createdAt    DateTime        @default(now())
  listing      PropertyListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  mediaAsset   MediaAsset      @relation(fields: [mediaAssetId], references: [id])

  @@index([listingId])
  @@index([sortOrder])
}

model SmartFeature {
  id        String                 @id @default(uuid())
  name      String
  slug      String                 @unique
  category  SmartFeatureCategory
  createdAt DateTime               @default(now())
  listings  PropertySmartFeature[]
}

model PropertySmartFeature {
  listingId      String
  smartFeatureId String
  createdAt      DateTime        @default(now())
  listing        PropertyListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  smartFeature   SmartFeature    @relation(fields: [smartFeatureId], references: [id], onDelete: Cascade)

  @@id([listingId, smartFeatureId])
  @@index([smartFeatureId])
}

model VerificationRecord {
  id                 String                          @id @default(uuid())
  entityType         VerificationEntityType
  entityId           String
  reviewerId         String
  outcome            VerificationOutcome
  notes              String?
  createdAt          DateTime                        @default(now())
  checklistResponses VerificationChecklistResponse[]
  reviewer           User                            @relation("VerificationReviewer", fields: [reviewerId], references: [id])

  @@index([entityType, entityId])
  @@index([reviewerId])
}

model VerificationChecklistItem {
  id         String                          @id @default(uuid())
  entityType VerificationEntityType
  key        String
  label      String
  isRequired Boolean                         @default(false)
  isActive   Boolean                         @default(true)
  sortOrder  Int                             @default(0)
  createdAt  DateTime                        @default(now())
  updatedAt  DateTime                        @updatedAt
  responses  VerificationChecklistResponse[]

  @@unique([entityType, key])
  @@index([entityType])
  @@index([isActive])
  @@index([sortOrder])
}

model VerificationChecklistResponse {
  id        String                    @id @default(uuid())
  recordId  String
  itemId    String
  value     Boolean
  notes     String?
  createdAt DateTime                  @default(now())
  item      VerificationChecklistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  record    VerificationRecord        @relation(fields: [recordId], references: [id], onDelete: Cascade)

  @@unique([recordId, itemId])
  @@index([itemId])
}

model MortgageBank {
  id          String               @id @default(uuid())
  name        String
  slug        String               @unique
  isSharia    Boolean              @default(false)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  products    MortgageProduct[]
  simulations MortgageSimulation[]
}

model MortgageProduct {
  id                     String               @id @default(uuid())
  bankId                 String
  name                   String
  slug                   String
  defaultInterestRate    Decimal?             @db.Decimal(6, 3)
  promoInterestRate      Decimal?             @db.Decimal(6, 3)
  fixedPeriodMonths      Int?
  floatingRateAssumption Decimal?             @db.Decimal(6, 3)
  shariaMargin           Decimal?             @db.Decimal(6, 3)
  adminFee               Decimal?             @db.Decimal(18, 2)
  insuranceRate          Decimal?             @db.Decimal(6, 3)
  provisiRate            Decimal?             @db.Decimal(6, 3)
  notaryFeeEstimate      Decimal?             @db.Decimal(18, 2)
  isActive               Boolean              @default(true)
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  minTenorMonths         Int?
  notes                  String?
  rateSchedule           Json?
  sourceCheckedAt        DateTime?
  sourceTitle            String?
  sourceUrl              String?
  bank                   MortgageBank         @relation(fields: [bankId], references: [id], onDelete: Cascade)
  simulations            MortgageSimulation[]

  @@unique([bankId, slug])
  @@index([bankId])
  @@index([isActive])
}

model MortgageSimulation {
  id        String           @id @default(uuid())
  userId    String?
  listingId String?
  bankId    String?
  productId String?
  inputs    Json
  results   Json
  createdAt DateTime         @default(now())
  bank      MortgageBank?    @relation(fields: [bankId], references: [id])
  listing   PropertyListing? @relation(fields: [listingId], references: [id])
  product   MortgageProduct? @relation(fields: [productId], references: [id])
  user      User?            @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([listingId])
  @@index([createdAt])
}

model Lead {
  id        String          @id @default(uuid())
  userId    String?
  listingId String
  name      String
  email     String?
  phone     String?
  message   String?
  source    LeadSource      @default(web)
  createdAt DateTime        @default(now())
  listing   PropertyListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user      User?           @relation(fields: [userId], references: [id])

  @@index([listingId])
  @@index([createdAt])
}

model Inquiry {
  id        String          @id @default(uuid())
  userId    String?
  listingId String
  name      String
  email     String?
  phone     String?
  message   String?
  createdAt DateTime        @default(now())
  listing   PropertyListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user      User?           @relation(fields: [userId], references: [id])

  @@index([listingId])
  @@index([createdAt])
}

model ViewingRequest {
  id          String               @id @default(uuid())
  listingId   String
  userId      String?
  preferredAt DateTime
  notes       String?
  status      ViewingRequestStatus @default(pending)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  listing     PropertyListing      @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user        User?                @relation(fields: [userId], references: [id])

  @@index([listingId])
  @@index([status])
}

model AdPackage {
  id           String        @id @default(uuid())
  type         AdPackageType @unique
  name         String
  price        Decimal       @db.Decimal(18, 2)
  durationDays Int
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  campaigns    AdCampaign[]

  @@index([isActive])
}

model AdCampaign {
  id          String           @id @default(uuid())
  adPackageId String
  developerId String
  projectId   String?
  listingId   String?
  status      AdCampaignStatus @default(draft)
  startsAt    DateTime?
  endsAt      DateTime?
  metadata    Json?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  adPackage   AdPackage        @relation(fields: [adPackageId], references: [id])
  developer   Developer        @relation(fields: [developerId], references: [id], onDelete: Cascade)
  listing     PropertyListing? @relation(fields: [listingId], references: [id])
  project     Project?         @relation(fields: [projectId], references: [id])

  @@index([developerId])
  @@index([status])
}

model ArticleCategory {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  articles  Article[]
}

model Article {
  id              String           @id @default(uuid())
  categoryId      String?
  title           String
  slug            String           @unique
  excerpt         String?
  content         String
  metaTitle       String?
  metaDescription String?
  authorName      String?
  tags            String[]
  status          ArticleStatus    @default(draft)
  publishedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  coverImageUrl   String?
  category        ArticleCategory? @relation(fields: [categoryId], references: [id])

  @@index([status])
  @@index([publishedAt])
}

model MediaAsset {
  id                 String              @id @default(uuid())
  kind               MediaKind
  storageProvider    StorageProvider     @default(s3_compat)
  bucket             String
  key                String
  url                String
  mimeType           String?
  sizeBytes          Int?
  width              Int?
  height             Int?
  createdAt          DateTime            @default(now())
  developerDocuments DeveloperDocument[]
  propertyImages     PropertyImage[]
  brochureListings   PropertyListing[]   @relation("BrochureAsset")

  @@index([kind])
  @@index([createdAt])
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  action     String
  entityType String?
  entityId   String?
  ip         String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([createdAt])
}

model Favorite {
  userId    String
  listingId String
  createdAt DateTime        @default(now())
  listing   PropertyListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, listingId])
  @@index([listingId])
}

model CompareList {
  id        String        @id @default(uuid())
  userId    String
  name      String        @default("Bandingkan")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  items     CompareItem[]
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CompareItem {
  id            String          @id @default(uuid())
  compareListId String
  listingId     String
  createdAt     DateTime        @default(now())
  compareList   CompareList     @relation(fields: [compareListId], references: [id], onDelete: Cascade)
  listing       PropertyListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([compareListId, listingId])
  @@index([listingId])
}

model SiteSettings {
  id          String   @id @default("default")
  socialLinks Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CmsPage {
  id              String     @id @default(uuid())
  slug            String     @unique
  title           String
  content         String?
  status          PageStatus @default(draft)
  metaTitle       String?
  metaDescription String?
  canonicalUrl    String?
  ogImageUrl      String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([status])
}

model SeoSettings {
  id                     String   @id @default("default")
  siteName               String   @default("Livinova")
  titleTemplate          String   @default("%s | Livinova")
  defaultMetaDescription String?
  robotsTxt              String?
  sitemapEnabled         Boolean  @default(true)
  googleSiteVerification String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model PropertyRating {
  id          String          @id @default(uuid())
  listingId   String
  rating      Int
  name        String?
  comment     String?
  isAnonymous Boolean         @default(false)
  createdAt   DateTime        @default(now())
  listing     PropertyListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([createdAt])
}

